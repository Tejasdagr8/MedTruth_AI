# ── Required ─────────────────────────────────────────────────────────────────
# Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=
# Groq API key fallback (get from console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Gemini API key fallback (get from ai.google.dev)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Local LLM fallback via Ollama (optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Optional ─────────────────────────────────────────────────────────────────
# NCBI API key — raises rate limit from 3 to 10 req/sec (free at ncbi.nlm.nih.gov/account)
NCBI_API_KEY=

# Claude model version
CLAUDE_MODEL=claude-sonnet-4-6

# Retrieval limits
PUBMED_MAX_RESULTS=8
EUROPEPMC_MAX_RESULTS=5

# NLI model for hallucination detection
NLI_MODEL=microsoft/deberta-v3-base-mnli

# Entailment threshold — claims below this score are flagged
ENTAILMENT_THRESHOLD=0.60

# Only add inline uncertainty prefix when support is very low
SEVERE_UNCERTAINTY_THRESHOLD=0.40

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./data/chroma_db

# BioBERT embedding model
EMBEDDING_MODEL=pritamdeka/BioBERT-mnli-snli-scinli-scitail-mednli-stsb

# CORS — comma-separated frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-long-random-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── User data store ──────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=medtruth_ai
